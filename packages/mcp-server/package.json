{
  "name": "@conduit/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Conduit MCP server: stdio MCP transport bridged to the Conduit native messaging host.",
  "bin": {
    "conduit-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/protocol": "*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
